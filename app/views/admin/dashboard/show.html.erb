<% content_for :title, "Admin Dashboard" %>

<div class="d-flex" style="min-height: 100vh; background-color: #fcfcfc;">
  <%# Sidebar %>
  <div class="bg-dark text-white p-4" style="width: 250px;">
    <div class="mb-5 d-flex align-items-center gap-2">
      <div class="wantu-avatar wantu-avatar--sidebar">
        <%= current_user.full_name.first(1).upcase %>
      </div>
      <span class="fs-5 fw-bold font-serif text-success">Wantu Admin</span>
    </div>
    <ul class="nav flex-column gap-3">
      <li class="nav-item">
        <a class="nav-link text-success p-0 fw-bold font-monospace" href="#top">Dashboard</a>
      </li>
      <div class="text-secondary small mt-4 mb-2 font-monospace text-uppercase" style="letter-spacing: 1px;">Manage</div>
      <li class="nav-item">
        <a class="nav-link text-white p-0 font-monospace opacity-75" href="#section-users">Users</a>
      </li>
      <li class="nav-item">
        <a class="nav-link text-white p-0 font-monospace opacity-75" href="#section-properties">Properties</a>
      </li>
      <li class="nav-item">
        <a class="nav-link text-white p-0 font-monospace opacity-75" href="#section-finances">Finances</a>
      </li>
    </ul>
  </div>

  <%# Main Content %>
  <div class="flex-grow-1 p-5">
    <%# Top Nav %>
    <div class="d-flex justify-content-end align-items-center gap-4 mb-5 font-monospace small">
      <span class="fw-bold"><%= current_user.email %></span>
      <%= link_to "&larr; Back to site".html_safe, root_path, class: "btn btn-outline-dark btn-sm px-3 fw-bold rounded-1" %>
      <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "btn btn-outline-dark btn-sm px-3 fw-bold rounded-1" %>
    </div>

    <h2 class="font-serif mb-4">Platform Overview</h2>

    <%# Stats Cards %>
    <div class="row g-3 mb-5">
      <div class="col-md-3">
        <div class="card border-dark rounded-2 text-center h-100">
          <div class="card-body d-flex flex-column justify-content-center">
            <h3 class="display-6 font-serif text-success fw-bold mb-1"><%= number_with_delimiter(@total_users) %></h3>
            <span class="text-uppercase small font-monospace text-muted fw-bold" style="letter-spacing:1px;">Total Users</span>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-dark rounded-2 text-center h-100">
          <div class="card-body d-flex flex-column justify-content-center">
            <h3 class="display-6 font-serif text-success fw-bold mb-1"><%= number_with_delimiter(@active_listings) %></h3>
            <span class="text-uppercase small font-monospace text-muted fw-bold" style="letter-spacing:1px;">Active Listings</span>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-dark rounded-2 text-center h-100">
          <div class="card-body d-flex flex-column justify-content-center">
            <h3 class="display-6 font-serif text-success fw-bold mb-1"><%= number_with_delimiter(@total_bookings) %></h3>
            <span class="text-uppercase small font-monospace text-muted fw-bold" style="letter-spacing:1px;">Total Bookings</span>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-dark rounded-2 text-center h-100">
          <div class="card-body d-flex flex-column justify-content-center">
            <h3 class="display-6 font-serif text-success fw-bold mb-1">Ksh <%= number_with_delimiter(@payments_received) %></h3>
            <span class="text-uppercase small font-monospace text-muted fw-bold" style="letter-spacing:1px;">Payments Received</span>
          </div>
        </div>
      </div>
    </div>

    <%# Users Table %>
    <h5 id="section-users" class="font-monospace fw-bold mb-3 mt-5">Users</h5>
    <div class="table-responsive mb-5">
      <table class="table table-bordered border-dark font-monospace text-nowrap">
        <thead class="table-light border-dark fw-bold">
          <tr>
            <th class="border-dark">ID</th>
            <th class="border-dark">Name</th>
            <th class="border-dark">Email</th>
            <th class="border-dark">Role</th>
            <th class="border-dark">Joined</th>
            <th class="border-dark">Actions</th>
          </tr>
        </thead>
        <tbody class="border-dark">
          <% @users.limit(5).each do |u| %>
            <tr>
              <td class="border-dark">#<%= u.id %></td>
              <td class="border-dark">
                <div class="d-flex align-items-center gap-2">
                  <div class="wantu-avatar wantu-avatar--sm"><%= u.full_name.first(1).upcase %></div>
                  <%= u.full_name %>
                </div>
              </td>
              <td class="border-dark"><%= u.email %></td>
              <td class="border-dark">
                <span class="border <%= u.agent? ? 'border-success text-success' : 'border-dark' %> px-2 py-1 rounded-1 small"><%= t("roles.#{u.role}") %></span>
              </td>
              <td class="border-dark"><%= u.created_at.to_date.to_fs(:short) %></td>
              <td class="border-dark">
                <button class="btn btn-sm btn-outline-dark rounded-1 fw-bold px-3">Edit</button>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%# Properties Table %>
    <h5 id="section-properties" class="font-monospace fw-bold mb-3">Properties</h5>
    <div class="table-responsive mb-5">
      <table class="table table-bordered border-dark font-monospace text-nowrap">
        <thead class="table-light border-dark fw-bold">
          <tr>
            <th class="border-dark">ID</th>
            <th class="border-dark">Title</th>
            <th class="border-dark">Agent</th>
            <th class="border-dark">Type</th>
            <th class="border-dark">Price</th>
            <th class="border-dark">Status</th>
            <th class="border-dark">Featured (sponsored)</th>
            <th class="border-dark">Actions</th>
          </tr>
        </thead>
        <tbody class="border-dark">
          <% @listings.limit(5).each do |l| %>
            <tr>
              <td class="border-dark">#<%= l.id %></td>
              <td class="border-dark"><%= l.title.truncate(20) %></td>
              <td class="border-dark"><%= l.user.full_name %></td>
              <td class="border-dark"><%= l.need_type.capitalize %>/<%= l.room_layout.titleize %></td>
              <td class="border-dark"><%= number_with_delimiter(l.price) %></td>
              <td class="border-dark">
                <span class="border <%= l.status == 'published' ? 'border-success text-success' : 'border-warning text-warning' %> px-2 py-1 rounded-1 small"><%= l.status.capitalize %></span>
              </td>
              <td class="border-dark"><%= l.featured ? 'Yes' : 'No' %></td>
              <td class="border-dark">
                <button class="btn btn-sm btn-outline-dark rounded-1 fw-bold px-2">Edit</button>
                <button class="btn btn-sm btn-outline-danger rounded-1 fw-bold px-2">Delete</button>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%# Finances Table %>
    <h5 id="section-finances" class="font-monospace fw-bold mb-3">Finances</h5>
    <div class="table-responsive w-50">
      <table class="table table-bordered border-dark font-monospace text-nowrap">
        <thead class="table-light border-dark fw-bold">
          <tr>
            <th class="border-dark">Total Processed</th>
            <th class="border-dark">Total Released</th>
            <th class="border-dark">Held in Escrow</th>
          </tr>
        </thead>
        <tbody class="border-dark">
          <tr>
            <td class="border-dark text-success fw-bold">Ksh <%= number_with_delimiter(@sum_processed) %></td>
            <td class="border-dark">Ksh <%= number_with_delimiter(@sum_released) %></td>
            <td class="border-dark">Ksh <%= number_with_delimiter(@sum_held) %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
