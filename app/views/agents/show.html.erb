<% content_for :title, "#{@agent.full_name} - #{t('users.agent_profile')}" %>

<section class="container py-4">
  <%# Agent header card %>
  <div class="card mb-5 border-dark rounded-3">
    <div class="card-body p-4">
      <div class="d-flex align-items-center gap-4 mb-4">
        <div class="wantu-agent-card__avatar wantu-agent-card__avatar--lg">
          <%= @agent.full_name.first(1).upcase %>
        </div>
        <div>
          <h2 class="mb-1 font-serif fw-bold"><%= @agent.full_name %></h2>
          <p class="text-muted mb-0 font-monospace text-uppercase small"><%= t("roles.#{@agent.role}") %> &nbsp;&nbsp;&nbsp; <%= @agent.listings.published.count %> <%= t('dashboard.my_listings', default: 'Listings') %></p>
        </div>
      </div>
      <hr class="border-dark opacity-100 my-4">
      <p class="mb-0 font-monospace small lh-lg"><%= t('accounts.bio_label', default: 'Bio') %>: <%= t('accounts.no_bio', default: 'No bio provided.') %></p>
    </div>
  </div>

  <%# Ratings & Reviews section %>
  <div class="mb-5">
    <h4 class="font-serif fw-bold mb-4"><%= t('agent_reviews.ratings_and_reviews', default: 'Ratings & Reviews') %></h4>
    <div class="d-flex align-items-end gap-5 mb-5">
      <div class="text-center">
        <div class="display-3 fw-bold text-success font-serif lh-1 mb-2"><%= number_with_precision(@avg_rating, precision: 1) || '0.0' %></div>
        <div class="text-warning fs-5 lh-1 mb-1">
          <% (@avg_rating || 0).floor.times do %>&#9733;<% end %>
          <% (5 - (@avg_rating || 0).floor).times do %><span class="text-muted">&#9733;</span><% end %>
        </div>
        <small class="text-muted d-block font-monospace"><%= t('agent_reviews.rating_count', count: @review_count, default: "#{@review_count} ratings") %></small>
      </div>
      <% if user_signed_in? && current_user.role != 'agent' %>
        <div class="mb-1">
          <%= link_to t('agent_reviews.write_review', default: 'Write a Review'), new_agent_review_path(agent_id: @agent.id), class: "btn btn-outline-dark px-3 py-1 font-monospace fw-bold rounded-2" %>
        </div>
      <% end %>
    </div>

    <% @reviews.limit(3).each do |review| %>
      <div class="card mb-3 border-dark rounded-3">
        <div class="card-body p-4">
          <div class="text-warning mb-3">
            <% review.rating.times do %>&#9733;<% end %>
            <% (5 - review.rating).times do %><span class="text-muted">&#9733;</span><% end %>
          </div>
          <% if review.title.present? %>
            <h6 class="fw-bold font-monospace mb-2"><%= review.title %></h6>
          <% end %>
          <p class="mb-4 font-monospace small"><%= review.body %></p>
          <div class="d-flex align-items-center gap-3 font-monospace small text-muted">
            <div class="wantu-agent-card__avatar wantu-agent-card__avatar--review">
              <%= review.author.full_name.first(1).upcase %>
            </div>
            <span class="text-lowercase"><%= review.author.full_name %></span>
            <span>- date of review <%= l(review.created_at.to_date, format: :long) rescue review.created_at.to_date %></span>
            <a href="#" class="text-decoration-none text-muted ms-3">Reply</a>
            
            <% if user_signed_in? && (review.author_id == current_user.id || current_user.admin?) %>
              <div class="ms-auto">
                <%= link_to t('actions.edit'), edit_agent_review_path(review), class: "text-primary text-decoration-none me-2" %>
                <%= button_to t('actions.delete'), agent_review_path(review), method: :delete, class: "btn btn-link text-danger p-0 m-0 text-decoration-none d-inline",
                    data: { turbo_confirm: t('prompts.confirm_delete') } %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <div class="mt-4">
      <%= link_to t('agent_reviews.see_all', default: 'See all agent reviews &rarr;').html_safe, "#", class: "text-decoration-none font-monospace small text-primary" %>
    </div>
  </div>

  <%# Agent Listings %>
  <h4 class="font-serif fw-bold mb-4"><%= t('agent_reviews.agent_listings', default: 'Agent Listings') %></h4>
  <% if @listings.any? %>
    <div class="row g-4 mt-2">
      <% @listings.each do |listing| %>
        <div class="col-sm-6 col-md-4">
          <%= render "shared/property_card", listing: listing %>
        </div>
      <% end %>
    </div>
    <%= render "shared/pagination", collection: @listings %>
  <% else %>
    <p class="text-muted"><%= t('dashboard.no_listings') %></p>
  <% end %>
</section>
