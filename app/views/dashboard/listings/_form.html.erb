<%= form_with model: [:dashboard, listing], class: "needs-validation", html: { multipart: true } do |f| %>
  <%# Basic Info %>
  <fieldset class="wantu-fieldset mb-4">
    <legend class="font-serif fw-bold text-uppercase fs-5 mb-3">1 <%= t('listings.fields.basic_information', default: 'BASIC INFORMATION') %></legend>
    <div class="mb-3">
      <%= f.label :title, t('listings.fields.title'), class: "form-label" %>
      <%= f.text_field :title,
          class: "form-control #{'is-invalid' if listing.errors[:title].any?}",
          placeholder: t('listings.placeholders.title') %>
      <% if listing.errors[:title].any? %>
        <div class="invalid-feedback d-block"><%= listing.errors[:title].join(", ") %></div>
      <% end %>
    </div>
    <div class="mb-3">
      <%= f.label :description, t('listings.fields.description'), class: "form-label" %>
      <%= f.text_area :description, rows: 5,
          class: "form-control #{'is-invalid' if listing.errors[:description].any?}",
          placeholder: t('listings.placeholders.description') %>
      <% if listing.errors[:description].any? %>
        <div class="invalid-feedback d-block"><%= listing.errors[:description].join(", ") %></div>
      <% end %>
    </div>
  </fieldset>

  <%# Type %>
  <fieldset class="wantu-fieldset mb-4">
    <legend class="font-serif fw-bold text-uppercase fs-5 mb-3">2 <%= t('listings.fields.property_type', default: 'PROPERTY TYPE') %></legend>
    <div class="row">
      <div class="col-md-4 mb-3">
        <p class="form-label fw-bold mb-2"><%= t('listings.fields.need_type') %></p>
        <div class="btn-group w-100" role="group">
          <% Listing::NEED_TYPES.each do |nt| %>
            <%= f.radio_button :need_type, nt, class: "btn-check", id: "need_type_#{nt}", checked: listing.need_type == nt || (listing.new_record? && nt == 'rent') %>
            <%= f.label "need_type_#{nt}", t("listings.need_type.#{nt}"), class: "btn btn-outline-success" %>
          <% end %>
        </div>
        <% if listing.errors[:need_type].any? %>
          <div class="invalid-feedback d-block"><%= listing.errors[:need_type].join(", ") %></div>
        <% end %>
      </div>
      <div class="col-md-4 mb-3">
        <%= f.label :use_case, t('listings.fields.use_case'), class: "form-label" %>
        <%= f.select :use_case,
            options_for_select(
              Listing::USE_CASES.map { |uc| [t("home.use_case_options.#{uc}"), uc] },
              listing.use_case
            ),
            { include_blank: false },
            class: "form-select #{'is-invalid' if listing.errors[:use_case].any?}" %>
        <% if listing.errors[:use_case].any? %>
          <div class="invalid-feedback d-block"><%= listing.errors[:use_case].join(", ") %></div>
        <% end %>
      </div>
      <div class="col-md-4 mb-3">
        <%= f.label :room_layout, t('listings.fields.room_layout'), class: "form-label" %>
        <%= f.select :room_layout,
            options_for_select(
              Listing::ROOM_LAYOUTS.map { |rl| [t("home.room_layout.#{rl}"), rl] },
              listing.room_layout
            ),
            { include_blank: false },
            class: "form-select #{'is-invalid' if listing.errors[:room_layout].any?}" %>
        <% if listing.errors[:room_layout].any? %>
          <div class="invalid-feedback d-block"><%= listing.errors[:room_layout].join(", ") %></div>
        <% end %>
      </div>
    </div>
  </fieldset>

  <%# Location %>
  <fieldset class="wantu-fieldset mb-4">
    <legend class="font-serif fw-bold text-uppercase fs-5 mb-3">3 <%= t('listings.fields.location') %></legend>
    <div class="row">
      <div class="col-md-4 mb-3">
        <label class="form-label fw-bold">Country</label>
        <select class="form-select" disabled><option>Kenya</option></select>
      </div>
      <div class="col-md-4 mb-3">
        <label class="form-label fw-bold">County</label>
        <select class="form-select" disabled><option>Nairobi</option></select>
      </div>
      <div class="col-md-4 mb-3">
        <%= f.label :location_id, "Sub-County / Area", class: "form-label fw-bold" %>
        <%= f.collection_select :location_id, @locations, :id, :area_name,
            { prompt: t('listings.fields.location') },
            class: "form-select #{'is-invalid' if listing.errors[:location_id].any?}" %>
        <% if listing.errors[:location_id].any? %>
          <div class="invalid-feedback d-block"><%= listing.errors[:location_id].join(", ") %></div>
        <% end %>
      </div>
    </div>
    <div class="row">
      <div class="col-md-12 mb-3">
        <%= f.label :building_name, t('listings.fields.building_name'), class: "form-label fw-bold" %>
        <%= f.text_field :building_name,
            class: "form-control",
            placeholder: t('listings.placeholders.building_name') %>
      </div>
    </div>
  </fieldset>

  <%# Photos %>
  <fieldset class="wantu-fieldset mb-4">
    <legend class="font-serif fw-bold text-uppercase fs-5 mb-3">4 <%= t('listings.fields.photos', default: 'PHOTOS') %></legend>
    <div class="mb-3">
      <label class="form-label fw-bold"><%= t('listings.hints.upload_photos', default: 'Upload property images') %></label>
      <div class="d-flex flex-wrap gap-2 mb-3">
        <% 5.times do |i| %>
          <div class="wantu-photo-slot d-flex align-items-center justify-content-center bg-light border rounded" style="width: 100px; height: 100px;">
            <span class="text-muted small fw-bold">Photo <%= i + 1 %></span>
          </div>
        <% end %>
      </div>
      <%= file_field_tag "images[]", multiple: true, class: "form-control", accept: 'image/png,image/gif,image/jpeg' %>
      <div class="form-text">Choose up to 5 images.</div>
    </div>
  </fieldset>

  <%# Pricing %>
  <fieldset class="wantu-fieldset mb-4">
    <legend class="font-serif fw-bold text-uppercase fs-5 mb-3">5 <%= t('listings.fields.pricing_details', default: 'PRICING & DETAILS') %></legend>
    <div class="row">
      <div class="col-md-4 mb-3">
        <%= f.label :price, t('listings.fields.price'), class: "form-label" %>
        <%= f.number_field :price, min: 1,
            class: "form-control #{'is-invalid' if listing.errors[:price].any?}" %>
        <% if listing.errors[:price].any? %>
          <div class="invalid-feedback d-block"><%= listing.errors[:price].join(", ") %></div>
        <% end %>
      </div>
      <div class="col-md-4 mb-3">
        <%= f.label :price_period, t('listings.fields.price_period'), class: "form-label" %>
        <%= f.select :price_period,
            options_for_select(
              Listing::PRICE_PERIODS.map { |pp_val| [pp_val.capitalize, pp_val] },
              listing.price_period
            ),
            { include_blank: false },
            class: "form-select" %>
      </div>
      <div class="col-md-4 mb-3">
        <%= f.label :viewing_fee, t('listings.fields.viewing_fee'), class: "form-label" %>
        <%= f.number_field :viewing_fee, min: 0,
            class: "form-control #{'is-invalid' if listing.errors[:viewing_fee].any?}" %>
        <% if listing.errors[:viewing_fee].any? %>
          <div class="invalid-feedback d-block"><%= listing.errors[:viewing_fee].join(", ") %></div>
        <% end %>
        <div class="form-text text-success mt-1"><%= t('listings.form.viewing_fee_hint') %></div>
      </div>
    </div>
    <div class="row">
      <div class="col-md-4 mb-3">
        <%= f.label :bathrooms, t('listings.fields.bathrooms'), class: "form-label" %>
        <%= f.number_field :bathrooms, min: 0, class: "form-control" %>
      </div>
    </div>
  </fieldset>

  <%# Listing Status %>
  <fieldset class="wantu-fieldset mb-4">
    <legend class="font-serif fw-bold text-uppercase fs-5 mb-3">6 <%= t('listings.fields.listing_status', default: 'LISTING STATUS') %></legend>
    <div class="mb-3">
      <div class="btn-group" role="group">
        <%= f.radio_button :status, 'published', class: "btn-check", id: "status_published", checked: listing.status == 'published' || listing.new_record? %>
        <%= f.label "status_published", "Available", class: "btn btn-outline-success" %>
        
        <%= f.radio_button :status, 'hidden', class: "btn-check", id: "status_hidden", checked: listing.status == 'hidden' %>
        <%= f.label "status_hidden", "Hidden", class: "btn btn-outline-success" %>
        
        <%= f.radio_button :status, 'draft', class: "btn-check", id: "status_draft", checked: listing.status == 'draft' %>
        <%= f.label "status_draft", "Draft", class: "btn btn-outline-success" %>
      </div>
    </div>
  </fieldset>

  <%# Submit %>
  <div class="wantu-form-actions d-flex gap-2 mt-4 pt-4 border-top">
    <%= f.submit t('actions.save', default: 'Save Details'), class: "wantu-btn wantu-btn--primary px-5 py-2 fs-5" %>
    <%= link_to t('actions.cancel', default: 'Cancel'), dashboard_listings_path, class: "btn btn-light px-4 py-2 border" %>
  </div>
<% end %>
