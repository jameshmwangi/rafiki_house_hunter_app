<nav class="wantu-navbar navbar-expand-lg">
  <div class="container wantu-navbar__inner">
    <%# Logo %>
    <%= link_to root_path, class: "wantu-logo" do %>
      <span class="wantu-logo__icon">W</span>
      <span class="wantu-logo__text"><%= t('app.name') %></span>
    <% end %>

    <%# Mobile toggle %>
    <button class="wantu-navbar__toggle" type="button"
            data-bs-toggle="collapse" data-bs-target="#mainNav"
            aria-controls="mainNav" aria-expanded="false"
            aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <%# Nav links %>
    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="wantu-navbar__links ms-auto me-4">
        <li><%= link_to t('home.need_type.rent'), listings_path(need_type: 'rent') %></li>
        <li><%= link_to t('home.need_type.buy'), listings_path(need_type: 'buy') %></li>
        <li><%= link_to t('home.need_type.bnb'), listings_path(need_type: 'bnb') %></li>
        <li><%= link_to t('nav.contact'), "#" %></li>
      </ul>

      <%# Right-side actions %>
      <div class="wantu-navbar__actions">
        <% if user_signed_in? %>
          <% if can? :access, :admin_dashboard %>
            <%= link_to t('nav.admin'), admin_root_path, class: "wantu-navbar__link" %>
          <% end %>
          <% if current_user.property_manager? %>
            <%= link_to t('nav.dashboard'), dashboard_path, class: "wantu-navbar__link" %>
          <% end %>
          <%= link_to t('nav.favourites'), favourites_path, class: "wantu-navbar__link" %>
          <%= link_to t('nav.account'), account_path, class: "wantu-navbar__link" %>
          <%= link_to t('nav.list_place'), new_dashboard_listing_path, class: "wantu-btn wantu-btn--blue" %>
          <%= button_to t('nav.logout'), destroy_user_session_path, method: :delete, class: "wantu-btn wantu-btn--white" %>
        <% else %>
          <%= link_to t('nav.list_place'), new_user_session_path(redirect_to: new_dashboard_listing_path), class: "wantu-btn wantu-btn--blue" %>
          <%= link_to t('nav.login'), new_user_session_path, class: "wantu-btn wantu-btn--white" %>
        <% end %>
      </div>
    </div>
  </div>
</nav>
