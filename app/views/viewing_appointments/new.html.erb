<% content_for :title, t('viewing_appointments.title') %>

<section class="container py-4">
  <h2 class="font-serif"><%= t('viewing_appointments.title') %></h2>

  <%# Property summary card %>
  <div class="card mb-4">
    <div class="card-body d-flex align-items-center gap-3">
      <% if @listing.property_images.any? && @listing.property_images.first.image.attached? %>
        <%= image_tag @listing.property_images.first.image,
            class: "rounded", style: "width:80px;height:80px;object-fit:cover;",
            alt: @listing.title %>
      <% end %>
      <div>
        <span class="wantu-badge wantu-badge--<%= @listing.need_type %>">
          <%= t("listings.need_type.#{@listing.need_type}") %>
        </span>
        <h5 class="mb-0"><%= @listing.title %>, <%= @listing.location.area_name %></h5>
        <p class="mb-0 text-muted"><%= @listing.room_layout.humanize %> &middot; <%= @listing.location.sub_county %></p>
        <span class="text-success fw-bold">Ksh <%= number_with_delimiter(@listing.price) %>/<%= @listing.price_period %></span>
      </div>
    </div>
  </div>

  <%# Agent card %>
  <div class="card mb-4">
    <div class="card-body">
      <small class="text-muted text-uppercase"><%= t('viewing_appointments.listing_owner') %></small>
      <div class="d-flex align-items-center gap-3 mt-2">
        <div class="wantu-avatar">
          <%= @listing.user.full_name.first(1).upcase %>
        </div>
        <div>
          <strong><%= @listing.user.full_name %></strong>
          <p class="mb-0 text-muted"><%= t("roles.#{@listing.user.role}") %> &middot; <%= @listing.user.listings.published.count %> <%= t('dashboard.my_listings') %></p>
        </div>
      </div>
    </div>
  </div>

  <%# Booking form %>
  <div class="row justify-content-center">
    <div class="col-md-8">
      <%= form_with model: @appointment, url: listing_viewing_appointments_path(@listing), class: "needs-validation" do |f| %>
        <div class="mb-4">
          <h5><%= t('viewing_appointments.fields.scheduled_at') %></h5>
          <p class="text-muted"><%= t('viewing_appointments.datetime_hint') %></p>
          <%= f.datetime_local_field :scheduled_at,
              class: "form-control #{'is-invalid' if @appointment.errors[:scheduled_at].any?}",
              min: 1.day.from_now.strftime('%Y-%m-%dT%H:%M') %>
          <% if @appointment.errors[:scheduled_at].any? %>
            <div class="invalid-feedback d-block"><%= @appointment.errors[:scheduled_at].join(", ") %></div>
          <% end %>
        </div>

        <%# Fee display & Payment Method %>
        <div class="card mb-4 border-success">
          <div class="card-body">
            <h5 class="font-serif"><%= t('viewing_appointments.physical_fee', default: 'Physical Viewing Fee') %></h5>
            <p class="text-muted small mb-4">Please note that all viewing fees are paid directly to Wantu and not to the Landlord to protect you from scams.</p>
            
            <h6 class="fw-bold mb-3">Select Payment Method</h6>
            <div class="d-flex gap-3 mb-4">
              <label class="wantu-btn wantu-btn--outline flex-fill text-center" style="cursor:pointer">
                <input type="radio" name="payment_method" value="mpesa" class="d-none" checked>
                M-Pesa
              </label>
              <label class="wantu-btn wantu-btn--outline flex-fill text-center" style="cursor:pointer">
                <input type="radio" name="payment_method" value="card" class="d-none">
                Card
              </label>
            </div>
            
            <div class="d-flex justify-content-between align-items-center bg-dark text-white p-3 rounded">
              <span class="fw-bold">Amount to Pay</span>
              <span class="fs-5 fw-bold text-success">Ksh <%= number_with_delimiter(@listing.viewing_fee) %></span>
            </div>
          </div>
        </div>

        <%# Payment Simulation %>
        <div class="card mb-4 border-dark rounded-3">
          <div class="card-body p-3">
            <h6 class="font-monospace fw-bold mb-3"><%= t('viewing_appointments.payment_simulation', default: 'Payment Simulation') %></h6>
            <div class="d-flex gap-4 font-monospace">
              <div class="form-check">
                <input class="form-check-input" type="radio" name="payment_simulation" id="payment_success" value="success" checked>
                <label class="form-check-label" for="payment_success">
                  <%= t('viewing_appointments.payment_success', default: 'Successful Payment') %>
                </label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="payment_simulation" id="payment_fail" value="fail">
                <label class="form-check-label" for="payment_fail">
                  <%= t('viewing_appointments.payment_fail', default: 'Failed Payment') %>
                </label>
              </div>
            </div>
          </div>
        </div>

        <div class="d-flex gap-2">
          <%= f.submit t('viewing_appointments.submit_payment', default: 'Complete Booking'), class: "wantu-btn wantu-btn--primary flex-grow-1 py-3 fs-5" %>
          <%= link_to t('actions.cancel'), listing_path(@listing), class: "wantu-btn wantu-btn--outline d-flex align-items-center px-4" %>
        </div>
      <% end %>
    </div>
  </div>
</section>
